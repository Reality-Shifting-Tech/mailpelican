    "bullmq": "^5.48.0",
    "drizzle-orm": "^0.43.1",
    "ioredis": "^5.6.0"
  },
  "devDependencies": {
    "@dispatch/testkit": "workspace:*",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.0"
  }
